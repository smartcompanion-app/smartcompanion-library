{
  "name": "smartcompanion",
  "author": "SmartCompanion Team <hello@smartcompanion.app> (https://smartcompanion.app) ",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test -w packages/data -w packages/services -w packages/ui --if-present",
    "build": "npm run build -w packages/data -w packages/services -w packages/ui -w apps/audioguide-app --if-present",
    "lint": "npm run lint -w packages/data -w packages/services --if-present",
    "format": "npm run format -w packages/data -w packages/services --if-present",
    "format:check": "npm run format:check -w packages/data -w packages/services --if-present"
  },
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@ionic/core": "^8.7.2",
    "@stencil/sass": "^3.2.1",
    "@types/jest": "^29.5.14",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.0"
  }
}
