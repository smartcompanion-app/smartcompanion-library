{
  "name": "@smartcompanion/services",
  "version": "0.6.3",
  "author": "SmartCompanion Team <hello@smartcompanion.app> (https://smartcompanion.app) ",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartcompanion-app/smartcompanion-library.git",
    "directory": "packages/services"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "jest": {
    "preset": "ts-jest/presets/js-with-ts",
    "testTimeout": 30000,
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  },
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@capacitor/core": "^7.4.2",
    "@smartcompanion/data": "*",
    "@smartcompanion/native-audio-player": "^0.2.0"
  }
}
