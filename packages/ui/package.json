{
  "name": "@smartcompanion/ui",
  "version": "0.6.2",
  "author": "SmartCompanion Team <hello@smartcompanion.app> (https://smartcompanion.app) ",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/smartcompanion-ui/smartcompanion-ui.esm.js",
  "files": [
    "src/",
    "dist/",
    "loader/"
  ],
  "license": "BSD-2-Clause",
  "scripts": {
    "build": "stencil build",
    "test": "npx playwright install --with-deps && npm run test-storybook:ci && npm run test:ci",
    "watch": "stencil build --watch",
    "storybook": "rm -rf dist/components && STORYBOOK=true storybook dev -p 6006 --no-open",
    "build-storybook": "rm -rf dist/components && STORYBOOK=true storybook build",
    "test:ci": "jest",
    "test-storybook:ci": "rm -rf dist/components && concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"STORYBOOK=true storybook dev -p 6006 --no-open\" \"npx wait-on tcp:127.0.0.1:6006 && test-storybook --testTimeout 60000\""
  },
  "jest": {
    "preset": "ts-jest",
    "testTimeout": 30000,
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@smartcompanion/services": "*",
    "@stencil/core": "^4.43.3",
    "@stencil/storybook-plugin": "^0.6.1",
    "@storybook/test-runner": "^0.24.3",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "shadow-dom-testing-library": "^1.13.1",
    "storybook": "^10.3.1",
    "wait-on": "^9.0.4"
  }
}
