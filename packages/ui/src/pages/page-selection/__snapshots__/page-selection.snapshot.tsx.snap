// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`render page selection in initial state 1`] = `
<sc-page-selection class="hydrated">
  <ion-header>
    <ion-toolbar color="primary">
      <ion-buttons slot="start">
        <ion-menu-button></ion-menu-button>
      </ion-buttons>
      <ion-title>
        Station Selection
      </ion-title>
    </ion-toolbar>
  </ion-header>
  <ion-content fullscreen>
    <div slot="fixed" class="station-selection-content">
      <div data-testid="numpad-input" class="numpad-input"></div>
      <sc-numpad class="hydrated">
        <mock:shadow-root>
          <ion-fab-button data-testid="numpad-button-1" data-value="1">
            1
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-2" data-value="2">
            2
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-3" data-value="3">
            3
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-4" data-value="4">
            4
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-5" data-value="5">
            5
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-6" data-value="6">
            6
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-7" data-value="7">
            7
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-8" data-value="8">
            8
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-9" data-value="9">
            9
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-delete">
            <ion-icon name="backspace-outline"></ion-icon>
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-0" data-value="0">
            0
          </ion-fab-button>
          <ion-fab-button data-testid="numpad-button-confirm">
            <ion-icon name="send-outline"></ion-icon>
          </ion-fab-button>
        </mock:shadow-root>
      </sc-numpad>
    </div>
  </ion-content>
</sc-page-selection>
`;
